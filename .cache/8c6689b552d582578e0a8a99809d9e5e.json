  "data": "<!DOCTYPE html>\n<html lang=\"pt-br\">\n<head>\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=windows-1252\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Verifica&ccedil;&atilde;o de Seguran&ccedil;a | SIG UFRB</title>\n    \n    <script src=\"https://challenges.cloudflare.com/turnstile/v0/api.js\" async defer></script>\n    \n   <style>\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        body { font-family: \"Open Sans\", Arial, sans-serif; font-size: 14px; background: #eaedf2; color: #333; line-height: 1.5; }\n\n        #sig-header { width: 100%; height: 80px; background: #fff; border-bottom: 3px solid #074e8c; display: flex; align-items: center; justify-content: space-between; padding: 0 40px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }\n        \n        /* SUAS ALTERAÇÕES DE LOGO AQUI */\n        .logo-ufrb img { width: 100px; height: auto; display: block; }\n        .sig-logo-box { display: flex; align-items: center; }\n        .sig-nome-sistema { font-size: 18px; font-weight: bold; color: #074e8c; margin-right: 15px; }\n        .sig-logo-box img { width: 100px; height: auto; } \n        \n        #sig-main { width: 100%; max-width: 650px; margin: 50px auto; padding: 0 15px; }\n        .sig-captcha-container { background: #fff; padding: 40px; border-radius: 4px; border: 1px solid #dcdcdc; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }\n        \n        .sig-title { font-size: 20px; font-weight: bold; color: #074e8c; margin-bottom: 20px; text-align: center; border-bottom: 1px solid #eee; padding-bottom: 10px; }\n        .sig-title-danger { color: #b30000; border-bottom-color: #ffcccc; }\n        \n        .sig-instrucoes { background: #f9f9f9; border-left: 4px solid #074e8c; padding: 15px; margin-bottom: 25px; text-align: left; }\n        .sig-instrucoes-danger { background: #fff5f5; border-left-color: #b30000; }\n        .sig-text { font-size: 14px; color: #444; margin-bottom: 10px; }\n        .sig-lista { margin-left: 20px; margin-bottom: 15px; color: #444; }\n        .sig-lista li { margin-bottom: 8px; }\n        \n        .cf-turnstile-container { display: flex; justify-content: center; margin: 20px 0; min-height: 65px; }\n        \n        .sig-footer { text-align: center; margin-top: 30px; }\n        .sig-button { padding: 12px 35px; font-size: 14px; font-weight: bold; background: #074e8c; color: white; border: none; border-radius: 3px; cursor: pointer; text-transform: uppercase; transition: background 0.3s; width: 100%; max-width: 300px; }\n        .sig-button:hover { background: #053c6d; }\n        \n        .sig-error-msg { background: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; padding: 12px; margin-bottom: 20px; border-radius: 4px; text-align: center; }\n        .sig-link-danger { color: #b30000; font-weight: bold; text-decoration: underline; }\n        .sig-link-danger:hover { color: #ff0000; }\n\n        /* === ADAPTAÇÕES PARA CELULAR (Telas menores que 600px) === */\n        @media (max-width: 600px) {\n            #sig-header { padding: 0 15px; height: 70px; }\n            \n            /* Diminuímos as duas logos proporcionalmente no celular para não espremer o cabeçalho */\n            .logo-ufrb img { width: 75px; } \n            .sig-logo-box img { width: 75px; } \n            \n            .sig-nome-sistema { font-size: 15px; margin-right: 10px; }\n            \n            #sig-main { margin: 30px auto; }\n            .sig-captcha-container { padding: 25px 20px; } \n            .sig-title { font-size: 18px; }\n        }\n        \n        /* Adaptação para telas EXTREMAMENTE pequenas */\n        @media (max-width: 360px) {\n            .sig-nome-sistema { display: none; } \n            .logo-ufrb img { width: 70px; }\n            .sig-logo-box img { width: 70px; }\n        }\n    </style>\n</head>\n<body>\n\n    <header id=\"sig-header\">\n        <div class=\"logo-ufrb\">\n            <img src=\"brasao2.png\" alt=\"UFRB\">\n        </div>\n        <div class=\"sig-logo-box\">\n            <span class=\"sig-nome-sistema\">SIG | UFRB</span>\n            <img src=\"brasao2.png\" alt=\"SIG Logo\">\n        </div>\n    </header>\n\n    <main id=\"sig-main\">\n        <div class=\"sig-captcha-container\">\n            \n                            <h1 class=\"sig-title\">Verifica&ccedil;&atilde;o de Seguran&ccedil;a</h1>\n                \n                <div class=\"sig-instrucoes\">\n                    <p class=\"sig-text\">\n                        Para proteger os sistemas da UFRB contra acessos maliciosos e garantir a estabilidade para a comunidade acad&ecirc;mica, a <strong>COTEC</strong> exige uma r&aacute;pida verifica&ccedil;&atilde;o antes de liberar o seu acesso.\n                    </p>\n                    <p class=\"sig-text\"><strong>O sistema ir&aacute; validar duas coisas:</strong></p>\n                    <ul class=\"sig-lista\">\n                        <li>Se voc&ecirc; &eacute; um <strong>usu&aacute;rio humano</strong> leg&iacute;timo (bloqueando rob&ocirc;s/bots autom&aacute;ticos).</li>\n                        <li>Se a sua conex&atilde;o atual possui uma <strong>reputa&ccedil;&atilde;o limpa</strong> (bloqueando IPs conhecidos como fontes de ataques).</li>\n                    </ul>\n                    <p class=\"sig-text\" style=\"font-size: 13px; color: #666; font-style: italic;\">\n                        Resolva o desafio abaixo para comprovar que voc&ecirc; &eacute; humano e iniciar a an&aacute;lise de seguran&ccedil;a do seu acesso.\n                    </p>\n                </div>\n                \n                \n                <form method=\"POST\">\n                    <div class=\"cf-turnstile-container\">\n                        <div class=\"cf-turnstile\" data-sitekey=\"0x4AAAAAACsUoQ5ElLmIrjbt\" data-theme=\"light\"></div>\n                    </div>\n                    \n                    <div class=\"sig-footer\">\n                        <button type=\"submit\" class=\"sig-button\">Iniciar Valida&ccedil;&atilde;o e Acessar</button>\n                    </div>\n                </form>\n            \n        </div>\n    </main>\n\n</body>\n</html>"
