  "data": "\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n \n\n<!-- Retorna para a tela de login antiga -->\n\n\n\n\n\n\n\n\n\n\n<!DOCTYPE html PUBLIC \"-//W3C//DTD HTML 4.01 Transitional//EN\"\n   \"http://www.w3.org/TR/html4/loose.dtd\">\n<html lang=\"pt-BR\" xmlns=\"http://www.w3.org/1999/xhtml\">\n\n\n\n\n\n\n\n\n\n\n\n\n\n<head>\n    <meta charset=\"ISO-8859-1\"/>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n    <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\"/>\n    \n    <title>SIGAA - Sistema Integrado de Gest&#227;o de Atividades Acad&#234;micas</title>\n\t<link class=\"component\" href=\"/sigaa/a4j/s/3_3_3.Finalorg/richfaces/renderkit/html/css/basic_classes.xcss/DATB/eAF7sqpgb-jyGdIAFrMEaw__.jsf;jsessionid=D5FF2649D2309380724FCA464E8A7F14.node1\" rel=\"stylesheet\" type=\"text/css\" /><link class=\"component\" href=\"/sigaa/a4j/s/3_3_3.Finalorg/richfaces/renderkit/html/css/extended_classes.xcss/DATB/eAF7sqpgb-jyGdIAFrMEaw__.jsf;jsessionid=D5FF2649D2309380724FCA464E8A7F14.node1\" media=\"rich-extended-skinning\" rel=\"stylesheet\" type=\"text/css\" /><script type=\"text/javascript\">window.RICH_FACES_EXTENDED_SKINNING_ON=true;</script><script src=\"/sigaa/a4j/g/3_3_3.Finalorg/richfaces/renderkit/html/scripts/skinning.js.jsf\" type=\"text/javascript\"></script><link rel=\"shortcut icon\" href=\"/sigaa/public/servicos_digitais/layout/static/images/favicon.ico\" />\n\t\n    <!-- Fonte Rawline-->\n    <link rel=\"stylesheet\" href=\"/sigaa/public/servicos_digitais/layout/static/vendors/fonts/rawline/css/rawline.css\"/>\n    <!-- Fonte Raleway-->\n    <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css?family=Raleway:300,400,500,600,700,800,900&amp;display=swap\"/>\n    <!-- Design System de Governo-->\n    <link rel=\"stylesheet\" href=\"/sigaa/public/servicos_digitais/layout/static/stylesheets/vendors/govbr/core.css\"/>\n    <!-- Fontawesome-->\n    <link rel=\"stylesheet\" href=\"/sigaa/public/servicos_digitais/layout/static/vendors/font-awesome/6.2.0/css/all.min.css\"/>\n    <!-- Estilo -->\n    <link rel=\"stylesheet\" href=\"/sigaa/public/servicos_digitais/layout/static/stylesheets/servicos-digitais.css\"/>\n    <!-- Estilos extras -->\n    <link rel=\"stylesheet\" href=\"/sigaa/public/servicos_digitais/layout/static/stylesheets/login.css\"/>\n</head>\n\n\n<body>\n    <div class=\"template-base\">\n      \t<main class=\"d-flex flex-fill mb-5\" id=\"main\">\n\t\t\t<div class=\"container-lg\">\n\t\t\t\t<div class=\"row\">\t\n\t\t\t\t\t<div class=\"col mb-5\">\t\n\t\t\t\t\t\t<!-- Mensagens -->\n\t\t\t\t\t\t\n\n\n\n\n\n\n\n\n\t\n\t\t\t\t\t\t<!-- Conte&#250;do -->\n\t\t\t\t\t\t<div class=\"main-content pl-sm-3 mt-4\" id=\"main-content\">\n\t\t\t\t\t\t\t\n\t\n\t\t\n\t\t\n\t\t\n\n\t\t<div class=\"row\">\n  \t\t\t<div class=\"col-sm-9 col-md-5 mx-auto\">\n\t\t\t\t<div class=\"br-card\">\n\t\t\t\t\t<div class=\"card-content\">\n\t\t\t\t\t\t<div id=\"painel-mensagens-login\"></div>\n\t\t\t\t\t\t\n<form id=\"formUsuario\" name=\"formUsuario\" method=\"post\" action=\"/sigaa/public/servicos_digitais/processo_seletivo/area_do_candidato/login.jsf;jsessionid=D5FF2649D2309380724FCA464E8A7F14.node1\" enctype=\"application/x-www-form-urlencoded\">\n<input type=\"hidden\" name=\"formUsuario\" value=\"formUsuario\" />\n\n\t\t\t\t\t\t\t<h3 class=\"text-center\">Acesso ao sistema</h3>\n\t\t\t\t\t\t\t<div class=\"mb-1\">\n\t\t\t\t\t\t\t\t\n<script type=\"text/javascript\" language=\"Javascript\">function dpf(f) {var adp = f.adp;if (adp != null) {for (var i = 0;i < adp.length;i++) {f.removeChild(adp[i]);}}};function apf(f, pvp) {var adp = new Array();f.adp = adp;var i = 0;for (k in pvp) {var p = document.createElement(\"input\");p.type = \"hidden\";p.name = k;p.value = pvp[k];f.appendChild(p);adp[i++] = p;}};function jsfcljs(f, pvp, t) {apf(f, pvp);var ft = f.target;if (t) {f.target = t;}f.submit();f.target = ft;dpf(f);};</script>\n<a id=\"entrarGovBr\" href=\"#\" onclick=\"if(typeof jsfcljs == 'function'){jsfcljs(document.getElementById('formUsuario'),{'entrarGovBr':'entrarGovBr','servico':'inscricao-processo-seletivo-lato-sensu'},'');}return false\" class=\"br-sign-in block mb-1 mt-3 primary botao-login\">\n\t\t\t\t\t\t\t\t\tEntrar com&nbsp;<span class=\"text-black\">gov.br</span>\n\t\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t<div class=\"mt-1\">\n\t\t\t\t\t\t\t\t<a id=\"login-estrangeiro\" href=\"#\" onclick=\"if(typeof jsfcljs == 'function'){jsfcljs(document.getElementById('formUsuario'),{'login-estrangeiro':'login-estrangeiro'},'');}return false\" class=\"br-button block\">Acessar como estrangeiro</a>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<input type=\"hidden\" name=\"javax.faces.ViewState\" id=\"javax.faces.ViewState\" value=\"j_id1\" />\n</form>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</main>\n      \n      <!-- Footer -->\n      <footer class=\"br-footer pt-3\" id=\"footer\">\n\t<div class=\"container-lg\">\n\t\t<div class=\"info\">\n\t\t\t<div class=\"text-down-01 text-medium pb-2\">\n\t\t\t\t<a class=\"logo-responsavel\" href=\"https://ufsb.edu.br/sti/\" title=\"Acessar a p&#225;gina da Superintend&#234;ncia de Tecnologia da Informa&#231;&#227;o\">\n\t\t\t\t\t<img src=\"/sigaa/public/servicos_digitais/layout/static/images/logo-responsavel-branco.png\" alt=\"Logotipo da Superintend&#234;ncia de Tecnologia da Informa&#231;&#227;o\" width=\"125\">\n\t\t\t\t</a>\n\t\t\t\t&nbsp;&nbsp;&nbsp;\n\t\t\t\tSuperintend&#234;ncia de Tecnologia da Informa&#231;&#227;o | Copyright &copy; 2006-2026 - UFSB\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</footer>\n    </div>\n    <!-- Required Js -->\n\t<script src=\"/sigaa/public/servicos_digitais/layout/static/javascripts/vendors/govbr-core-init.js\"></script>\n\t<!-- JQuery -->\n\t<script src=\"/sigaa/public/servicos_digitais/layout/static/javascripts/vendors/jquery.js\"></script>\n\t\n\t<script src=\"/sigaa/public/servicos_digitais/layout/static/javascripts/vendors/jquery.mask.min.js\"></script>\n\t\n\t<script src=\"/sigaa/public/servicos_digitais/layout/static/javascripts/servicos-digitais.js\"></script>\n\t\n\t<script type=\"text/javascript\" src=\"/sigaa/public/servicos_digitais/layout/static/javascripts/arquivo.js\"></script>\n\t\n\t<!-- Javascript extra -->\n\t<script type=\"text/javascript\" src=\"/sigaa/public/servicos_digitais/layout/static/javascripts/login.js\"></script>\n<!-- MYFACES JAVASCRIPT -->\n\n</body>\n\n</html>"
